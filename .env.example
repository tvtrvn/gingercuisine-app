NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Restaurant info
RESTAURANT_NAME="(RESTAURANT_NAME)"
RESTAURANT_ADDRESS="(ADDRESS)"
RESTAURANT_PHONE="(PHONE)"
NEXT_PUBLIC_RESTAURANT_PHONE="(PHONE)"
# Marketing-copy hours string (optional). When unset, derived automatically
# from HOURS_SCHEDULE below, so the website and the order-gate stay in sync.
# RESTAURANT_HOURS="Monday – Sunday: 11:00 AM – 11:00 PM"

# ── Online ordering window ────────────────────────────────────────────
# IANA timezone the schedule below is interpreted in. Defaults to
# America/Toronto.
# HOURS_TIMEZONE=America/Toronto
#
# Weekly schedule, Monday → Sunday, comma-separated. Each entry is either
# `HH:MM-HH:MM` (24h, open-close) or `closed`. The website refuses to
# accept new online orders outside these windows.
# Default: open 11:00 AM – 11:00 PM every day.
# HOURS_SCHEDULE=11:00-23:00,11:00-23:00,11:00-23:00,11:00-23:00,11:00-23:00,11:00-23:00,11:00-23:00
#
# Stop accepting new online orders this many minutes BEFORE the close
# time, so the kitchen has time to prep the last tickets. Default: 15.
# LAST_ORDER_LEAD_MIN=15

# Default region for parsing phone numbers (client + server). ISO 3166-1 alpha-2, e.g. CA, US.
# NEXT_PUBLIC_PHONE_DEFAULT_REGION=CA

# Taxes (e.g. 0.13 for 13% HST)
TAX_RATE=0.13

# Resend email (or replace with another email provider)
RESEND_API_KEY=your_resend_api_key_here
RESEND_DOMAIN=yourdomain.com
RESEND_FROM_EMAIL=onboarding@resend.dev

RESTAURANT_ORDER_EMAIL=orders@example.com
RESTAURANT_CONTACT_EMAIL=contact@example.com
NEXT_PUBLIC_RESTAURANT_CONTACT_EMAIL=contact@example.com

# MongoDB (Prisma)
DATABASE_URL=mongodb+srv://USER:PASS@cluster.mongodb.net/gingercuisine?appName=Cluster0

# ── MongoDB heartbeat (keeps Atlas M0 from auto-pausing) ──────────────
# Random string. Vercel Cron sends "Authorization: Bearer ${CRON_SECRET}"
# automatically; the heartbeat route rejects requests without it.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Restaurant dashboard (tablet)
# Shared password staff enter on /dashboard/login.
DASHBOARD_PASSWORD=change-me-please
# 32+ char random string used to sign the session cookie.
DASHBOARD_SESSION_SECRET=replace-with-a-long-random-string
# Optional: override the polling interval (ms) for the dashboard.
# DASHBOARD_POLL_INTERVAL_MS=4000
# Optional: how many hours of completed/cancelled history show on the live
# board (default 72 = last three days). Older orders are reachable via
# the search bar. Set to 24 for a tighter view, 168 for a full week.
# DASHBOARD_HISTORY_WINDOW_HOURS=72

# ── Rate limiting (REQUIRED for production) ────────────────────────────
# Upstash Redis. Create a free DB at https://console.upstash.com/,
# open it → "REST API" tab → copy the URL + token.
# If left blank, rate limiting is DISABLED and the server logs a warning.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
