NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Restaurant info
RESTAURANT_NAME="(RESTAURANT_NAME)"
RESTAURANT_ADDRESS="(ADDRESS)"
RESTAURANT_PHONE="(PHONE)"
NEXT_PUBLIC_RESTAURANT_PHONE="(PHONE)"
RESTAURANT_HOURS="(HOURS)"

# Taxes (e.g. 0.13 for 13% HST)
TAX_RATE=0.13

# Resend email (or replace with another email provider)
RESEND_API_KEY=your_resend_api_key_here
RESEND_DOMAIN=yourdomain.com
RESEND_FROM_EMAIL=onboarding@resend.dev

RESTAURANT_ORDER_EMAIL=orders@example.com
RESTAURANT_CONTACT_EMAIL=contact@example.com
NEXT_PUBLIC_RESTAURANT_CONTACT_EMAIL=contact@example.com

# MongoDB (Prisma)
DATABASE_URL=mongodb+srv://USER:PASS@cluster.mongodb.net/gingercuisine?appName=Cluster0

# Restaurant dashboard (tablet)
# Shared password staff enter on /dashboard/login.
DASHBOARD_PASSWORD=change-me-please
# 32+ char random string used to sign the session cookie.
DASHBOARD_SESSION_SECRET=replace-with-a-long-random-string
# Optional: override the polling interval (ms) for the dashboard.
# DASHBOARD_POLL_INTERVAL_MS=4000

# ── Rate limiting (REQUIRED for production) ────────────────────────────
# Upstash Redis. Create a free DB at https://console.upstash.com/,
# open it → "REST API" tab → copy the URL + token.
# If left blank, rate limiting is DISABLED and the server logs a warning.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
