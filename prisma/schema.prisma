// Prisma schema for Ginger Cuisine.
// Source of truth: MongoDB (Atlas).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Order {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  orderCode         String    @unique

  // Payment
  paymentMethod     String    @default("pay_in_person") // "pay_in_person"
  paymentStatus     String    @default("unpaid")        // "unpaid" | "paid"

  // Kitchen workflow
  orderStatus       String    @default("new")           // "new" | "acknowledged" | "preparing" | "ready" | "completed" | "cancelled"
  posEntryStatus    String    @default("not_entered")   // "not_entered" | "entered"
  source            String    @default("website")       // "website"

  // Pickup
  pickupName        String
  pickupPhone       String
  pickupEmail       String?
  pickupTimeOption  String
  pickupTime        String?

  // Cart
  itemsJson         String
  subtotal          Float
  tax               Float
  total             Float

  // Optional staff note / internal comments
  staffNote         String?

  // Random token shared only with the customer who placed the order,
  // required to view the confirmation page. Prevents enumeration of
  // other customers' orders by guessing order codes.
  viewToken         String?

  // Timestamps for status transitions (helpful for dashboard)
  acknowledgedAt    DateTime?
  readyAt           DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([orderStatus])
  @@index([createdAt])
}
