// Prisma schema for Ginger Cuisine.
// Source of truth: MongoDB (Atlas).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Order {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  orderCode         String    @unique

  // Payment
  paymentMethod     String    @default("pay_in_person") // "pay_in_person"
  paymentStatus     String    @default("unpaid")        // "unpaid" | "paid"

  // Kitchen workflow
  orderStatus       String    @default("new")           // "new" | "acknowledged" | "ready" | "completed" | "cancelled"
  source            String    @default("website")       // "website"

  // Pickup
  pickupName        String
  pickupPhone       String
  pickupEmail       String?
  pickupTimeOption  String
  pickupTime        String?

  // Cart
  itemsJson         String
  subtotal          Float
  tax               Float
  total             Float

  // Optional staff note / internal comments
  staffNote         String?

  // Random token shared only with the customer who placed the order,
  // required to view the confirmation page. Prevents enumeration of
  // other customers' orders by guessing order codes.
  viewToken         String?

  // Timestamps for status transitions (helpful for dashboard)
  acknowledgedAt    DateTime?
  readyAt           DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([orderStatus])
  @@index([createdAt])
  // Composite: the dashboard's main query is "active OR recent" ordered by
  // createdAt desc. This index lets Mongo serve the active half without a scan.
  @@index([orderStatus, createdAt(sort: Desc)])
  // Helps prefix search on name. Full-substring search still scans, but any
  // startsWith-style query (and exact match) becomes O(log n).
  @@index([pickupName])
  @@index([pickupPhone])
}

// Key/value store for restaurant-wide runtime toggles that the dashboard can
// flip without a code deploy. Currently holds the "pause online ordering"
// flag, but more keys can be added (e.g. "holiday_message").
//
// `value` is JSON-encoded so we can change the shape per-key without
// migrating MongoDB documents.
model RestaurantSetting {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
